@page "/EventTraces/{eventId:guid}"
@using Microsoft.AspNetCore.Authorization
@model Icp.Ui.Pages.EventTraces.DetailsModel
@attribute [Authorize]

@{
    ViewData["Title"] = "Event Trace Details";

    static string FormatStatus(string status)
    {
        return status.ToLowerInvariant() switch
        {
            "succeeded" => "✅",
            "failed" => "❌",
            "running" => "⏳",
            _ => "⏳"
        };
    }

    static string GetStatusClass(string status)
    {
        return status.ToLowerInvariant() switch
        {
            "succeeded" => "status-succeeded",
            "failed" => "status-failed",
            "running" => "status-running",
            _ => "status-pending"
        };
    }
}

<div class="page-header">
    <a href="/" class="back-link">&larr; Back to Home</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="panel">
        <div class="msg msg-error">@Model.ErrorMessage</div>
    </div>
}
else if (Model.Trace is not null)
{
    <h1>Event Trace</h1>
    <div class="panel">
        <div class="trace-info">
            <div class="trace-info-row">
                <div class="trace-info-label">Event ID</div>
                <div class="trace-info-value"><code>@Model.Trace.EventId</code></div>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.Trace.CorrelationId))
            {
                <div class="trace-info-row">
                    <div class="trace-info-label">Correlation ID</div>
                    <div class="trace-info-value"><code>@Model.Trace.CorrelationId</code></div>
                </div>
            }
            <div class="trace-info-row">
                <div class="trace-info-label">Account</div>
                <div class="trace-info-value">@Model.Trace.AccountKey</div>
            </div>
            <div class="trace-info-row">
                <div class="trace-info-label">Event Type</div>
                <div class="trace-info-value">@Model.Trace.EventType</div>
            </div>
            <div class="trace-info-row">
                <div class="trace-info-label">Status</div>
                <div class="trace-info-value">
                    <span class="status-badge @GetStatusClass(Model.Trace.Status)">@Model.Trace.Status</span>
                </div>
            </div>
            <div class="trace-info-row">
                <div class="trace-info-label">Current Stage</div>
                <div class="trace-info-value"><span class="stage-badge">@Model.Trace.CurrentStage</span></div>
            </div>
            <div class="trace-info-row">
                <div class="trace-info-label">Received At (UTC)</div>
                <div class="trace-info-value">@Model.Trace.ReceivedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</div>
            </div>
            <div class="trace-info-row">
                <div class="trace-info-label">Last Updated (UTC)</div>
                <div class="trace-info-value">@Model.Trace.LastUpdatedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</div>
            </div>
            @if (Model.Trace.MatchedInstanceCount > 0)
            {
                <div class="trace-info-row">
                    <div class="trace-info-label">Matched Instances</div>
                    <div class="trace-info-value">@Model.Trace.MatchedInstanceCount</div>
                </div>
                <div class="trace-info-row">
                    <div class="trace-info-label">Success / Failure</div>
                    <div class="trace-info-value">@Model.Trace.SuccessCount / @Model.Trace.FailureCount</div>
                </div>
            }
        </div>
    </div>

    <h1>Event Steps</h1>
    <div class="panel">
        @if (Model.Steps.Count == 0)
        {
            <div class="muted">No steps recorded yet.</div>
        }
        else
        {
            <div class="table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Step</th>
                            <th>Status</th>
                            <th>Started (UTC)</th>
                            <th>Completed (UTC)</th>
                            <th>Duration</th>
                            <th>Instance</th>
                            <th>Target</th>
                            <th>Message</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var step in Model.Steps)
                        {
                            var duration = step.CompletedAtUtc.HasValue
                                ? (step.CompletedAtUtc.Value - step.StartedAtUtc).TotalMilliseconds
                                : (double?)null;
                            var durationText = duration.HasValue
                                ? $"{duration.Value:N0} ms"
                                : "-";

                            <tr>
                                <td><code>@step.StepName</code></td>
                                <td>
                                    <span class="status-badge @GetStatusClass(step.Status)">
                                        @FormatStatus(step.Status) @step.Status
                                    </span>
                                </td>
                                <td class="cell-nowrap">@step.StartedAtUtc.ToString("HH:mm:ss.fff")</td>
                                <td class="cell-nowrap">@(step.CompletedAtUtc?.ToString("HH:mm:ss.fff") ?? "-")</td>
                                <td class="cell-nowrap">@durationText</td>
                                <td>
                                    @if (step.InstanceId.HasValue)
                                    {
                                        <a href="/Instances/Details/@step.InstanceId">@step.InstanceId.Value.ToString()[..8]...</a>
                                    }
                                    else
                                    {
                                        <span class="muted">-</span>
                                    }
                                </td>
                                <td>@(step.TargetType ?? "-")</td>
                                <td class="cell-message">@(step.Message ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

<style>
    .page-header {
        margin-bottom: 24px;
    }

    .back-link {
        color: rgba(148, 163, 184, 1);
        text-decoration: none;
        font-size: 14px;
    }

    .back-link:hover {
        color: rgba(59, 130, 246, 1);
    }

    .trace-info {
        display: grid;
        gap: 12px;
    }

    .trace-info-row {
        display: grid;
        grid-template-columns: 180px 1fr;
        gap: 16px;
        align-items: baseline;
    }

    .trace-info-label {
        color: rgba(148, 163, 184, 1);
        font-size: 13px;
    }

    .trace-info-value {
        font-weight: 500;
    }

    .trace-info-value code {
        font-family: 'Consolas', 'Monaco', monospace;
        font-size: 13px;
        background: rgba(148, 163, 184, 0.1);
        padding: 2px 6px;
        border-radius: 4px;
    }

    .table-wrapper {
        overflow-x: auto;
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
    }

    .data-table th,
    .data-table td {
        text-align: left;
        padding: 10px 12px;
        border-bottom: 1px solid rgba(148, 163, 184, 0.15);
    }

    .data-table th {
        color: rgba(148, 163, 184, 1);
        font-weight: 500;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .data-table tbody tr:hover {
        background: rgba(148, 163, 184, 0.05);
    }

    .data-table code {
        font-family: 'Consolas', 'Monaco', monospace;
        font-size: 12px;
        background: rgba(148, 163, 184, 0.1);
        padding: 2px 6px;
        border-radius: 4px;
    }

    .cell-nowrap {
        white-space: nowrap;
    }

    .cell-message {
        max-width: 300px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 8px;
        border-radius: 4px;
        font-size: 12px;
        font-weight: 500;
        white-space: nowrap;
    }

    .status-succeeded {
        background: rgba(34, 197, 94, 0.15);
        color: rgba(34, 197, 94, 1);
    }

    .status-failed {
        background: rgba(239, 68, 68, 0.15);
        color: rgba(239, 68, 68, 1);
    }

    .status-running,
    .status-pending {
        background: rgba(234, 179, 8, 0.15);
        color: rgba(234, 179, 8, 1);
    }

    .stage-badge {
        display: inline-block;
        padding: 3px 8px;
        border-radius: 4px;
        font-size: 12px;
        font-weight: 500;
        background: rgba(148, 163, 184, 0.15);
        color: rgba(148, 163, 184, 1);
        white-space: nowrap;
    }

    .muted {
        color: rgba(148, 163, 184, 0.7);
    }
</style>
