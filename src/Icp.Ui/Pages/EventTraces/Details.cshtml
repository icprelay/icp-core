@page "/EventTraces/{eventId:guid}"
@using Microsoft.AspNetCore.Authorization
@model Icp.Ui.Pages.EventTraces.DetailsModel
@attribute [Authorize]

@{
    ViewData["Title"] = "Event Trace Details";

    static string FormatStatus(string status)
    {
        return status.ToLowerInvariant() switch
        {
            "succeeded" => "✅",
            "failed" => "❌",
            "running" => "⏳",
            _ => "⏳"
        };
    }

    static string GetStatusClass(string status)
    {
        return status.ToLowerInvariant() switch
        {
            "succeeded" => "status-succeeded",
            "failed" => "status-failed",
            "running" => "status-running",
            _ => "status-pending"
        };
    }

    static string GetStageFromStep(string stepName)
    {
        var parts = stepName.Split('.');
        return parts.Length > 0 ? parts[0] : stepName;
    }

    static int GetPhaseOrder(string stepName)
    {
        return stepName.ToLowerInvariant() switch
        {
            "ingest.received" => 1,
            "mapper.started" => 2,
            "mapper.completed" => 3,
            "ingest.completed" => 4,
            "dispatch.started" => 5,
            "dispatch.completed" => 6,
            "target.started" => 7,
            "target.completed" => 7, // Same phase as target.started to group by instance
            _ => 99
        };
    }

    static int GetSubStepOrder(string stepName)
    {
        // Within a target instance group, started comes before completed
        return stepName.ToLowerInvariant().EndsWith(".started") ? 0 : 1;
    }

    // Group and order steps logically
    // For target steps: group by instance, then started before completed
    var orderedSteps = Model.Steps
        .OrderBy(s => GetPhaseOrder(s.StepName))
        .ThenBy(s => s.InstanceId)
        .ThenBy(s => GetSubStepOrder(s.StepName))
        .ThenBy(s => s.TimestampUtc)
        .ToList();
}

<div class="page-header">
    <a href="/" class="back-link">&larr; Back to Home</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="panel">
        <div class="msg msg-error">@Model.ErrorMessage</div>
    </div>
}
else if (Model.Trace is not null)
{
    <h1>Event Trace</h1>
    <div class="panel">
        <div class="trace-info">
            <div class="trace-info-row">
                <div class="trace-info-label">Event ID</div>
                <div class="trace-info-value"><code>@Model.Trace.EventId</code></div>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.Trace.CorrelationId))
            {
                <div class="trace-info-row">
                    <div class="trace-info-label">Correlation ID</div>
                    <div class="trace-info-value"><code>@Model.Trace.CorrelationId</code></div>
                </div>
            }
            <div class="trace-info-row">
                <div class="trace-info-label">Account</div>
                <div class="trace-info-value">@Model.Trace.AccountKey</div>
            </div>
            <div class="trace-info-row">
                <div class="trace-info-label">Event Type</div>
                <div class="trace-info-value">@Model.Trace.EventType</div>
            </div>
            <div class="trace-info-row">
                <div class="trace-info-label">Status</div>
                <div class="trace-info-value">
                    <span class="status-badge @GetStatusClass(Model.Trace.Status)">@Model.Trace.Status</span>
                </div>
            </div>
            <div class="trace-info-row">
                <div class="trace-info-label">Current Stage</div>
                <div class="trace-info-value"><span class="stage-badge">@Model.Trace.CurrentStage</span></div>
            </div>
            <div class="trace-info-row">
                <div class="trace-info-label">Received At (UTC)</div>
                <div class="trace-info-value">@Model.Trace.ReceivedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</div>
            </div>
            <div class="trace-info-row">
                <div class="trace-info-label">Last Updated (UTC)</div>
                <div class="trace-info-value">@Model.Trace.LastUpdatedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</div>
            </div>
            @if (Model.Trace.MatchedInstanceCount > 0)
            {
                <div class="trace-info-row">
                    <div class="trace-info-label">Matched Instances</div>
                    <div class="trace-info-value">@Model.Trace.MatchedInstanceCount</div>
                </div>
                <div class="trace-info-row">
                    <div class="trace-info-label">Success / Failure</div>
                    <div class="trace-info-value">@Model.Trace.SuccessCount / @Model.Trace.FailureCount</div>
                </div>
            }
        </div>
    </div>

    <h1>Event Steps</h1>
    <div class="panel">
        @if (Model.Steps.Count == 0)
        {
            <div class="muted">No steps recorded yet.</div>
        }
        else
        {
            <div class="timeline">
                @{
                    var currentStage = "";
                    DateTime? previousTimestamp = null;
                }
                @foreach (var step in orderedSteps)
                {
                    var stage = GetStageFromStep(step.StepName);
                    var isNewStage = stage != currentStage;
                    currentStage = stage;

                    var statusClass = GetStatusClass(step.Status);

                    // Calculate delta from previous step
                    var delta = previousTimestamp.HasValue
                        ? (step.TimestampUtc - previousTimestamp.Value).TotalSeconds
                        : (double?)null;
                    var deltaText = delta.HasValue
                        ? $"{delta.Value:N1}s"
                        : null;
                    previousTimestamp = step.TimestampUtc;

                    <div class="timeline-item @(isNewStage ? "timeline-item-new-stage" : "")">
                        @if (deltaText != null)
                        {
                            <div class="timeline-delta">@deltaText</div>
                        }
                        <div class="timeline-marker @statusClass"></div>
                        <div class="timeline-content">
                            <div class="timeline-header">
                                <span class="timeline-step">@step.StepName</span>
                                <span class="status-badge @statusClass">@FormatStatus(step.Status)</span>
                            </div>
                            <div class="timeline-meta">
                                <span class="timeline-time">@step.TimestampUtc.ToString("HH:mm:ss")</span>
                                @if (step.InstanceId.HasValue)
                                {
                                    <span class="timeline-separator">·</span>
                                    <a href="/Instances/history?instanceId=@step.InstanceId" class="timeline-link">@step.InstanceId.Value.ToString()[..8]...</a>
                                }
                                @if (!string.IsNullOrWhiteSpace(step.TargetType))
                                {
                                    <span class="timeline-separator">·</span>
                                    <span class="timeline-target">@step.TargetType</span>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(step.Message))
                            {
                                <div class="timeline-message">@step.Message</div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}

<style>
    .page-header {
        margin-bottom: 24px;
    }

    .back-link {
        color: rgba(148, 163, 184, 1);
        text-decoration: none;
        font-size: 14px;
    }

    .back-link:hover {
        color: rgba(59, 130, 246, 1);
    }

    .trace-info {
        display: grid;
        gap: 12px;
    }

    .trace-info-row {
        display: grid;
        grid-template-columns: 180px 1fr;
        gap: 16px;
        align-items: baseline;
    }

    .trace-info-label {
        color: rgba(148, 163, 184, 1);
        font-size: 13px;
    }

    .trace-info-value {
        font-weight: 500;
    }

    .trace-info-value code {
        font-family: 'Consolas', 'Monaco', monospace;
        font-size: 13px;
        background: rgba(148, 163, 184, 0.1);
        padding: 2px 6px;
        border-radius: 4px;
    }

    /* Timeline styles */
    .timeline {
        position: relative;
        padding-left: 24px;
        margin-left: 60px;
    }

    .timeline::before {
        content: '';
        position: absolute;
        left: 7px;
        top: 8px;
        bottom: 8px;
        width: 2px;
        background: rgba(148, 163, 184, 0.2);
        border-radius: 1px;
    }

    .timeline-item {
        position: relative;
        padding: 12px 0;
        padding-left: 16px;
    }

    .timeline-item-new-stage {
        margin-top: 8px;
    }

    .timeline-delta {
        position: absolute;
        left: -65px;
        top: 14px;
        font-size: 11px;
        font-family: 'Consolas', 'Monaco', monospace;
        color: rgba(59, 130, 246, 0.9);
        background: rgba(59, 130, 246, 0.1);
        padding: 2px 6px;
        border-radius: 4px;
        white-space: nowrap;
    }

    .timeline-marker {
        position: absolute;
        left: -20px;
        top: 16px;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        border: 2px solid;
        background: #0f172a;
    }

    .timeline-marker.status-succeeded {
        border-color: rgba(34, 197, 94, 1);
        background: rgba(34, 197, 94, 0.2);
    }

    .timeline-marker.status-failed {
        border-color: rgba(239, 68, 68, 1);
        background: rgba(239, 68, 68, 0.2);
    }

    .timeline-marker.status-running,
    .timeline-marker.status-pending {
        border-color: rgba(234, 179, 8, 1);
        background: rgba(234, 179, 8, 0.2);
    }

    .timeline-content {
        background: rgba(148, 163, 184, 0.08);
        border-radius: 8px;
        padding: 12px 16px;
        border: 1px solid rgba(148, 163, 184, 0.1);
    }

    .timeline-header {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .timeline-step {
        font-family: 'Consolas', 'Monaco', monospace;
        font-size: 14px;
        font-weight: 600;
        color: #111519;
    }

    .timeline-meta {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-top: 6px;
        font-size: 13px;
        color: rgba(203, 213, 225, 0.9);
        flex-wrap: wrap;
    }

    .timeline-time {
        font-family: 'Consolas', 'Monaco', monospace;
        color: rgba(148, 163, 184, 1);
    }

    .timeline-separator {
        color: rgba(148, 163, 184, 0.5);
    }

    .timeline-link {
        color: rgba(96, 165, 250, 1);
        text-decoration: none;
    }

    .timeline-link:hover {
        text-decoration: underline;
    }

    .timeline-target {
        background: rgba(148, 163, 184, 0.15);
        padding: 2px 8px;
        border-radius: 4px;
        color: rgba(104, 113, 125, 0.9);
    }

    .timeline-message {
        margin-top: 8px;
        padding: 8px 10px;
        background: rgba(239, 68, 68, 0.1);
        border-left: 3px solid rgba(239, 68, 68, 0.5);
        border-radius: 0 4px 4px 0;
        font-size: 13px;
        color: rgba(252, 165, 165, 1);
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 11px;
        font-weight: 500;
        white-space: nowrap;
    }

    .status-succeeded {
        background: rgba(34, 197, 94, 0.15);
        color: rgba(34, 197, 94, 1);
    }

    .status-failed {
        background: rgba(239, 68, 68, 0.15);
        color: rgba(239, 68, 68, 1);
    }

    .status-running,
    .status-pending {
        background: rgba(234, 179, 8, 0.15);
        color: rgba(234, 179, 8, 1);
    }

    .stage-badge {
        display: inline-block;
        padding: 3px 8px;
        border-radius: 4px;
        font-size: 12px;
        font-weight: 500;
        background: rgba(148, 163, 184, 0.15);
        color: rgba(148, 163, 184, 1);
        white-space: nowrap;
    }

    .muted {
        color: rgba(148, 163, 184, 0.7);
    }
</style>
