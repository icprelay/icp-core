@page
@using Microsoft.AspNetCore.Authorization
@model Icp.Ui.Pages.Instances.SecretsModel
@attribute [Authorize]

@{
    ViewData["Title"] = "Instance secrets";
}

<h1>Instance secrets</h1>

<div class="panel">
    @if (!string.IsNullOrWhiteSpace(Model.Error))
    {
        <div class="msg msg-error">@Model.Error</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.Message))
    {
        <div class="msg msg-ok">@Model.Message</div>
    }

    <div class="muted">InstanceId</div>
    <div class="mono" style="margin: 6px 0 14px;">@Model.InstanceId</div>

    <p class="muted" style="margin-top: 0;">
        Enter secrets as one per line: <span class="mono">key=value</span>. Values are written to the secret store; they are not shown again.
    </p>

    <form method="post">
        <input type="hidden" name="customerId" value="@Model.CustomerId" />
        <input type="hidden" name="instanceId" value="@Model.InstanceId" />

        <p>
            <textarea class="form-control" name="secretsText" rows="12" cols="80">@Model.SecretsText</textarea>
        </p>

        <div class="actions">
            <button class="btn" type="submit">Save secrets</button>
            <a class="btn" href="/Instances?customerId=@Model.CustomerId">Back</a>
        </div>
    </form>
</div>
