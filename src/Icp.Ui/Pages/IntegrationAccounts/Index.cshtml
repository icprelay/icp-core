@page
@using Icp.Ui
@using Microsoft.AspNetCore.Authorization
@model Icp.Ui.Pages.IntegrationAccounts.IndexModel
@attribute [Authorize]

@{
    ViewData["Title"] = "Integration Accounts";
}

<h1>Integration accounts</h1>

@if (!string.IsNullOrWhiteSpace(Model.Error))
{
    <div class="alert-danger">@Model.Error</div>
}

<div class="panel">
    <div class="form-row" style="justify-content: space-between; align-items:center;">
        <a class="btn" href="@Url.Page("/IntegrationAccounts/Create")">Add new</a>
        <a class="btn" href="@Url.Page("/IntegrationAccounts/Index")">Refresh</a>
    </div>

    <div style="margin-top: 12px; overflow-x: auto; overflow-y: visible;">
        <table class="icp-table" style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="text-align:left; border-bottom: 1px solid rgba(15, 23, 42, 0.12);">
                    <th style="padding: 12px 12px; width:70px;">Enabled</th>
                    <th style="padding: 12px 12px;">Name</th>
                    <th style="padding: 12px 12px;">External customer id</th>
                    <th style="padding: 12px 12px; width:110px;">Instances</th>
                    <th style="padding: 12px 12px; width:180px;">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Items.Count == 0)
            {
                <tr>
                    <td colspan="5" style="padding: 12px 12px; color: #475569;">No integration accounts.</td>
                </tr>
            }
            else
            {
                foreach (var item in Model.Items)
                {
                    var a = item.Account;
                    <tr style="border-bottom: 1px solid rgba(15, 23, 42, 0.08);">
                        <td style="padding: 12px 12px;">
                            <form method="post" asp-page-handler="@(a.Enabled ? "Disable" : "Enable")" style="display:inline;">
                                <input type="hidden" name="accountId" value="@a.AccountId" />
                                <label class="icp-switch" title="Enabled">
                                    <input type="checkbox" @(a.Enabled ? "checked" : null) onchange="this.form.submit()" />
                                    <span class="icp-slider"></span>
                                </label>
                            </form>
                        </td>
                        <td style="padding: 12px 12px; overflow-wrap:anywhere;">
                            @if (!string.IsNullOrWhiteSpace(a.DisplayName))
                            {
                                <div style="font-weight: 600;">@a.DisplayName</div>
                            }
                        </td>
                        <td style="padding: 12px 12px; overflow-wrap:anywhere;">
                            <code>@a.ExternalCustomerId</code>
                        </td>
                        <td style="padding: 12px 12px;">
                            @item.InstanceCount
                        </td>
                        <td style="padding: 12px 12px;">
                            <div class="icp-actions">
                                <details class="icp-dropdown" style="position: relative; display: inline-block;">
                                    <summary class="btn" style="list-style: none;">Create instance</summary>
                                    <div class="icp-dropdown-menu" style="position: fixed; z-index: 9999; margin-top: 8px; min-width: 220px; background: #fff; border: 1px solid #ddd; border-radius: 10px; overflow: hidden; box-shadow: 0 12px 24px rgba(0,0,0,0.12);">
                                        <a class="icp-dropdown-item" style="display:block; padding: 12px 14px; text-decoration:none; color: inherit; border-bottom: 1px solid #eee; transition: background-color 120ms ease, color 120ms ease;" href="/Instances/Create?accountId=@a.AccountId&triggerType=Event">
                                            <img src="@Url.Content(IconMappings.GetFluentSvgUrlOrDefault(IconMappings.GetTriggerIconKey("Event"), fallbackIconKey: "doc"))" width="16" height="16" style="vertical-align:-3px; margin-right:8px; opacity:.9;" alt="" />
                                            Event trigger
                                        </a>
                                        <a class="icp-dropdown-item" style="display:block; padding: 12px 14px; text-decoration:none; color: inherit; border-bottom: 1px solid #eee; transition: background-color 120ms ease, color 120ms ease;" href="/Instances/Create?accountId=@a.AccountId&triggerType=Schedule">
                                            <img src="@Url.Content(IconMappings.GetFluentSvgUrlOrDefault(IconMappings.GetTriggerIconKey("Schedule"), fallbackIconKey: "doc"))" width="16" height="16" style="vertical-align:-3px; margin-right:8px; opacity:.9;" alt="" />
                                            Schedule trigger
                                        </a>
                                        <a class="icp-dropdown-item" style="display:block; padding: 12px 14px; text-decoration:none; color: inherit; border-bottom: 1px solid #eee; transition: background-color 120ms ease, color 120ms ease;" href="/Instances/Create?accountId=@a.AccountId&triggerType=OnDemand">
                                            <img src="@Url.Content(IconMappings.GetFluentSvgUrlOrDefault(IconMappings.GetTriggerIconKey("OnDemand"), fallbackIconKey: "doc"))" width="16" height="16" style="vertical-align:-3px; margin-right:8px; opacity:.9;" alt="" />
                                            On-Demand
                                        </a>
                                    </div>
                                </details>
                            </div>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>

    <style>
        table.icp-table th,
        table.icp-table td {
            padding: 12px 12px;
        }

        .icp-actions {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            align-items: center;
        }

        .icp-actions .btn {
            padding: 7px 10px;
        }

        .icp-dropdown-item:hover {
            background-color: #f6f7f9;
        }

        .icp-dropdown[open] > summary.btn {
            box-shadow: 0 0 0 3px rgba(0,0,0,0.06);
        }

        code {
            background: rgba(15, 23, 42, 0.04);
            border: 1px solid rgba(15, 23, 42, 0.08);
            padding: 2px 6px;
            border-radius: 8px;
        }

        .alert-danger {
            margin-top: 10px;
            padding: 10px 12px;
            border-radius: 12px;
            border: 1px solid rgba(220, 38, 38, 0.35);
            background: rgba(220, 38, 38, 0.06);
            color: #7f1d1d;
        }
    </style>

    <script>
        (function () {
            function placeMenu(details) {
                var summary = details.querySelector('summary');
                var menu = details.querySelector('.icp-dropdown-menu');
                if (!summary || !menu) return;

                var r = summary.getBoundingClientRect();
                var top = r.bottom + 8;
                var left = r.left;

                // keep within viewport
                var maxLeft = window.innerWidth - menu.offsetWidth - 12;
                if (left > maxLeft) left = Math.max(12, maxLeft);

                menu.style.top = top + 'px';
                menu.style.left = left + 'px';
            }

            document.addEventListener('toggle', function (e) {
                var d = e.target;
                if (!(d instanceof HTMLDetailsElement)) return;
                if (!d.classList.contains('icp-dropdown')) return;
                if (d.open) {
                    placeMenu(d);
                    // Close other open dropdowns
                    document.querySelectorAll('details.icp-dropdown[open]').forEach(function (other) {
                        if (other !== d) other.removeAttribute('open');
                    });
                }
            }, true);

            window.addEventListener('scroll', function () {
                document.querySelectorAll('details.icp-dropdown[open]').forEach(function (d) {
                    placeMenu(d);
                });
            }, true);

            window.addEventListener('resize', function () {
                document.querySelectorAll('details.icp-dropdown[open]').forEach(function (d) {
                    placeMenu(d);
                });
            });

            document.addEventListener('click', function (e) {
                document.querySelectorAll('details.icp-dropdown[open]').forEach(function (d) {
                    if (!d.contains(e.target)) d.removeAttribute('open');
                });
            });
        })();
    </script>
</div>
